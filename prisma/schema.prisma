// ============================================================================
// PROSPECT FANTASY
// ============================================================================

model FantasyFeaturedEvent {
  id                   String           @id @default(cuid())
  title                String
  slug                 String           @unique
  description          String?
  year                 Int?
  /// Max contests a user may enter for rollup (e.g. 5 classes)
  maxClassPicks        Int              @default(5)
  /// How many top contest scores count toward featured-event total (e.g. 2)
  bestClassScoresCount Int              @default(2)
  isFeatured           Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  contests             FantasyContest[]

  @@index([slug])
  @@index([isFeatured])
  @@map("FantasyFeaturedEvents")
}

/// REGIONAL_QUALIFIER | NATIONAL_CHAMPIONSHIP | RACE
model FantasyContest {
  id                 String                  @id @default(cuid())
  featuredEventId    String
  featuredEvent      FantasyFeaturedEvent    @relation(fields: [featuredEventId], references: [id], onDelete: Cascade)
  type               String
  classLabel         String
  pickCount          Int
  lockAt             DateTime
  /// draft | open | locked | live | scoring | final | void
  status             String                  @default("draft")
  rulesSummary       String?
  tieBreakerLabel    String?
  tieBreakerRequired Boolean                 @default(false)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  raceEventId        String?
  raceEventClassId   String?
  raceEvent          RaceEvent?              @relation(fields: [raceEventId], references: [id], onDelete: SetNull)
  raceEventClass     RaceEventClass?         @relation(fields: [raceEventClassId], references: [id], onDelete: SetNull)
  entries            FantasyEntry[]
  officialResults    FantasyOfficialResult[]
  scores             FantasyScore[]

  @@index([featuredEventId])
  @@index([status, lockAt])
  @@index([raceEventId])
  @@index([raceEventClassId])
  @@map("FantasyContests")
}

model FantasyEntry {
  id               String         @id @default(cuid())
  contestId        String
  contest          FantasyContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  submittedAt      DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tieBreakerValue  String?
  /// Class this lineup is for (user-chosen for RACE; mirrors contest.raceEventClassId for other types).
  raceEventClassId String
  raceEventClass   RaceEventClass @relation(fields: [raceEventClassId], references: [id], onDelete: Restrict)
  picks            FantasyPick[]
  score            FantasyScore?

  @@unique([contestId, userId, raceEventClassId])
  @@index([contestId])
  @@index([userId])
  @@index([raceEventClassId])
  @@map("FantasyEntries")
}

model FantasyPick {
  id       String       @id @default(cuid())
  entryId  String
  entry    FantasyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  position Int
  riderId  String
  rider    RiderId      @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([entryId, position])
  @@unique([entryId, riderId])
  @@index([entryId])
  @@map("FantasyPicks")
}

model FantasyOfficialResult {
  id        String         @id @default(cuid())
  contestId String
  contest   FantasyContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  position  Int
  riderId   String
  rider     RiderId        @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([contestId, position])
  @@unique([contestId, riderId])
  @@index([contestId])
  @@map("FantasyOfficialResults")
}

model FantasyScore {
  id            String         @id @default(cuid())
  entryId       String         @unique
  entry         FantasyEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  contestId     String
  contest       FantasyContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  totalPoints   Int            @default(0)
  /// Per-slot breakdown for debugging/display
  breakdownJson Json?
  resultVersion Int            @default(0)
  computedAt    DateTime       @default(now())

  @@index([contestId, totalPoints])
  @@index([contestId])
  @@map("FantasyScores")
}

model ProspectGroup {
  id              String                @id @default(cuid())
  name            String
  inviteCode      String                @unique
  createdByUserId String
  createdBy       User                  @relation("ProspectGroupCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  groupAvatarUrl  String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  members         ProspectGroupMember[]
  invites         ProspectGroupInvite[]

  @@index([inviteCode])
  @@map("ProspectGroups")
}

model ProspectGroupMember {
  id       String        @id @default(cuid())
  groupId  String
  group    ProspectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime      @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("ProspectGroupMembers")
}

/// pending | accepted | expired
model ProspectGroupInvite {
  id               String        @id @default(cuid())
  groupId          String
  group            ProspectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  token            String        @unique
  email            String?
  phoneE164        String?
  status           String        @default("pending")
  acceptedAt       DateTime?
  acceptedByUserId String?
  acceptedBy       User?         @relation("ProspectGroupInviteAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())

  @@index([groupId])
  @@index([email])
  @@index([phoneE164])
  @@map("ProspectGroupInvites")
}

// ============================================================================
// PROSPECT GIVEAWAY ENGINE
// ============================================================================

/// CHALLENGE | SWEEPSTAKE
model GiveawayCampaign {
  id                  String     @id @default(cuid())
  slug                String     @unique
  type                String
  crmBrandId          String
  CrmBrand            CrmBrand   @relation(fields: [crmBrandId], references: [id], onDelete: Cascade)
  title               String
  description         String?    @db.Text
  rules               String?    @db.Text
  avatarUrl           String?
  coverPhotoUrl       String?
  countdownEndsAt     DateTime?
  displayStartAt      DateTime?
  displayEndAt        DateTime?
  enrollmentOpensAt   DateTime?
  enrollmentClosesAt  DateTime?
  /// draft | open | closed | final | void
  status              String     @default("draft")
  targetRaceEventId   String?
  targetRaceEvent     RaceEvent? @relation(fields: [targetRaceEventId], references: [id], onDelete: SetNull)
  currentTermsVersion String     @default("1")
  scoringConfigJson   Json?
  outcomeConfigJson   Json?
  checklistConfigJson Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  promoters       GiveawayCampaignPromoter[]
  eligibleClasses GiveawayCampaignEligibleRaceClass[]
  enrollments     GiveawayEnrollment[]
  challengeScores GiveawayChallengeScore[]
  riderOutcomes   GiveawayRiderOutcome[]
  sweepstakeDraws GiveawaySweepstakeDraw[]

  @@index([status, displayStartAt, displayEndAt])
  @@index([crmBrandId])
  @@index([targetRaceEventId])
  @@map("GiveawayCampaigns")
}

model GiveawayCampaignPromoter {
  id             String           @id @default(cuid())
  campaignId     String
  campaign       GiveawayCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  racePromoterId String
  racePromoter   RacePromoter     @relation(fields: [racePromoterId], references: [id], onDelete: Cascade)

  @@unique([campaignId, racePromoterId])
  @@index([racePromoterId])
  @@map("GiveawayCampaignPromoters")
}

model GiveawayCampaignEligibleRaceClass {
  campaignId       String
  campaign         GiveawayCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  raceEventClassId String
  raceEventClass   RaceEventClass   @relation(fields: [raceEventClassId], references: [id], onDelete: Cascade)

  @@id([campaignId, raceEventClassId])
  @@map("GiveawayCampaignEligibleRaceClasses")
}

/// started | qualified | disqualified
/// CHALLENGE: one row per (campaign, user, rider) — riderId is the entrant. SWEEPSTAKE: user-level row with riderId null.
model GiveawayEnrollment {
  id                               String           @id @default(cuid())
  campaignId                       String
  campaign                         GiveawayCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId                           String
  user                             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  riderId                          String?
  rider                            RiderId?         @relation(fields: [riderId], references: [id], onDelete: SetNull)
  termsVersion                     String?
  termsAcceptedAt                  DateTime?
  declaredNoConflictingSponsorship Boolean          @default(false)
  noConflictDeclaredAt             DateTime?
  optInAt                          DateTime         @default(now())
  qualificationStatus              String           @default("started")
  leadTier                         Int?
  sourceChannel                    String?
  checklistStateJson               Json?
  nearestDealerId                  String?
  nearestDealer                    Dealer?          @relation("GiveawayEnrollmentNearestDealer", fields: [nearestDealerId], references: [id], onDelete: SetNull)
  preferredDealerId                String?
  preferredDealer                  Dealer?          @relation("GiveawayEnrollmentPreferredDealer", fields: [preferredDealerId], references: [id], onDelete: SetNull)
  dealerMatchComputedAt            DateTime?
  profileSnapshotJson              Json?
  zipOrPostcode                    String?
  createdAt                        DateTime         @default(now())
  updatedAt                        DateTime         @updatedAt

  challengeScore         GiveawayChallengeScore?
  winningSweepstakeDraws GiveawaySweepstakeDraw[] @relation("GiveawayDrawWinnerEnrollment")

  /// Uniqueness: partial unique indexes in migrations — (campaignId,userId,riderId) when riderId set; (campaignId,userId) when riderId is null.
  @@index([campaignId, userId])
  @@index([campaignId, qualificationStatus])
  @@index([riderId])
  @@map("GiveawayEnrollments")
}

model GiveawayChallengeScore {
  id                             String             @id @default(cuid())
  enrollmentId                   String             @unique
  enrollment                     GiveawayEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  campaignId                     String
  campaign                       GiveawayCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  primaryScore                   Int                @default(0)
  tieBreakerTop3Laps             Int                @default(0)
  tieBreakerBestSingleMotoTop5   Int                @default(0)
  tieBreakerFinalMotoPlaceNumber Int?
  breakdownJson                  Json?
  leaderboardRank                Int?
  computedAt                     DateTime           @default(now())
  resultVersion                  Int                @default(0)

  @@index([campaignId, primaryScore])
  @@index([campaignId, leaderboardRank])
  @@map("GiveawayChallengeScores")
}

/// WINNER | FINALIST | RUNNER_UP | DRAW_WINNER | COMPLETED
model GiveawayRiderOutcome {
  id               String           @id @default(cuid())
  campaignId       String
  campaign         GiveawayCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  riderId          String
  rider            RiderId          @relation(fields: [riderId], references: [id], onDelete: Cascade)
  outcomeType      String
  rank             Int?
  label            String?
  metadataJson     Json?
  awardedAt        DateTime         @default(now())
  assignedByUserId String?
  assignedBy       User?            @relation("GiveawayOutcomeAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([riderId, awardedAt])
  @@map("GiveawayRiderOutcomes")
}

model GiveawaySweepstakeDraw {
  id                  String              @id @default(cuid())
  campaignId          String
  campaign            GiveawayCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  winningEnrollmentId String?
  winningEnrollment   GiveawayEnrollment? @relation("GiveawayDrawWinnerEnrollment", fields: [winningEnrollmentId], references: [id], onDelete: SetNull)
  drawnAt             DateTime            @default(now())
  drawnByUserId       String?
  drawnBy             User?               @relation("GiveawayDrawRecorder", fields: [drawnByUserId], references: [id], onDelete: SetNull)
  auditNotes          String?             @db.Text
  rngMetadataJson     Json?

