// Admin-managed ad package pricing templates
model BrandAdPackage {
  id        String   @id @default(cuid())
  platform  String // "APP" or "WEB"
  scope     String // "NATIONAL", "STATE", or "METRO"
  state     String? // State code (e.g., "TX") if scope is STATE
  metro     String? // Metro area name if scope is METRO
  price     Float // Monthly price
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lineItems BrandAdLineItem[]

  @@unique([platform, scope, state, metro])
  @@index([platform, scope, isActive])
  @@map("BrandAdPackages")
}

// Purchased ad orders
model BrandAdOrder {
  id            String    @id @default(cuid())
  brandId       String
  orderDate     DateTime  @default(now())
  status        String    @default("PENDING") // "PENDING", "ACTIVE", "COMPLETED", "CANCELLED"
  totalCost     Float
  startDate     DateTime?
  endDate       DateTime?
  monthlyBudget Float? // Monthly spend cap for this order
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  brand     CrmBrand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  lineItems BrandAdLineItem[]

  @@index([brandId])
  @@index([status])
  @@index([orderDate])
  @@map("BrandAdOrders")
}

// Individual ad placements within an order
model BrandAdLineItem {
  id                String   @id @default(cuid())
  orderId           String
  packageId         String
  creativeId        String? // Optional creative assignment
  platform          String // "APP" or "WEB"
  scope             String // "NATIONAL", "STATE", or "METRO"
  targeting         Json? // JSON object: { states: [], cities: [], metros: [] }
  googleAdManagerId String? // Google Ad Manager line item ID (for future integration)
  status            String   @default("PENDING") // "PENDING", "ACTIVE", "COMPLETED", "CANCELLED"
  impressions       Int      @default(0)
  clicks            Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  order    BrandAdOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package  BrandAdPackage   @relation(fields: [packageId], references: [id])
  creative BrandAdCreative? @relation(fields: [creativeId], references: [id])

  @@index([orderId])
  @@index([packageId])
  @@index([status])
  @@index([googleAdManagerId])
  @@map("BrandAdLineItems")
}

// Monthly budget configuration per brand
model BrandAdMonthlyBudget {
  id                   String   @id @default(cuid())
  brandId              String   @unique
  amount               Float // Monthly budget amount
  autoRefillEnabled    Boolean  @default(false)
  stripeSubscriptionId String? // Stripe subscription ID if auto-refill enabled
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  brand CrmBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@map("BrandAdMonthlyBudgets")
}

// Ad creatives (artwork) for brand advertising
model BrandAdCreative {
  id         String   @id @default(cuid())
  brandId    String
  imageUrl   String
  type       String // "app-banner", "web-banner", etc.
  dimensions String // "320 × 50", "728 × 90", etc.
  status     String   @default("PENDING") // "APPROVED", "PENDING", "REJECTED"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  brand     CrmBrand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  lineItems BrandAdLineItem[]

  @@index([brandId])
  @@index([status])
  @@map("BrandAdCreatives")
}

