// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "tracing"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

model RacePromoter {
  id                          String                     @id @default(cuid())
  name                        String
  slug                        String?                    @default(cuid())
  signupSlug                  String?                    @default("")
  photoUrl                    String?
  coverPhotoUrl               String?
  scoringSystemType           String
  scoringSystemUrl            String
  isLive                      Boolean                    @default(false)
  isResultsEnabled            Boolean                    @default(false)
  isLiveEnabled               Boolean                    @default(false)
  isSignupEnabled             Boolean                    @default(false)
  isEnhancedLiveTimingEnabled Boolean                    @default(false)
  state                       String?                    @default("")
  zipCode                     String?                    @default("")
  RaceEvents                  RaceEvent[]
  RaceEventSignups            RaceEventSignup[]
  PromoterRiderIdentifiers    PromoterRiderIdentifier[]
  RaceSeries                  RaceSeries[]
  Tracks                      Track[]
  OffroadRaceEvents           OffroadRaceEvent[]
  GiveawayCampaignPromoters   GiveawayCampaignPromoter[]
}

model RaceEvent {
  id                       String                  @id @default(cuid())
  name                     String
  displayName              String? // Admin-curated title; falls back to name in UI
  date                     DateTime
  endDate                  DateTime? // End date for multi-day events
  location                 String
  city                     String                  @default("")
  state                    String                  @default("")
  latitude                 Float?
  longitude                Float?
  isGeoCoded               Boolean                 @default(false)
  isHidden                 Boolean                 @default(false)
  isIncomplete             Boolean                 @default(false) // True while multi-day event is still running
  isNotificationsProcessed Boolean                 @default(false) // True when UserNotifications have been created for this event
  eventUrl                 String
  scoringSystemEventId     String
  scoringTier              String                  @default("1")
  score                    Float?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt // Track when event was last updated
  RaceEventClasses         RaceEventClass[]
  RaceSeriesEvents         RaceSeriesEvent[]
  RacePromoter             RacePromoter            @relation(fields: [racePromoterId], references: [id])
  racePromoterId           String
  trackId                  String?
  Track                    Track?                  @relation(fields: [trackId], references: [id])
  NewsItems                NewsFeedItemToEvent[]
  coverImageUrl            String? // Optional override for cover image
  avatarImageUrl           String? // Optional override for avatar image
  PhotoGalleries           RaceEventPhotoGallery[]
  RaceEventClassPhotos     RaceEventClassPhoto[]
  FantasyContests          FantasyContest[]
  GiveawayCampaigns        GiveawayCampaign[]
  TracksideRaceInfos       TracksideRaceInfo[]

  @@index([id]) // Index for related includes
  @@index([score, id], map: "race_event_score_id_idx")
  @@index([isIncomplete, racePromoterId]) // Index for finding incomplete events
  @@index([isIncomplete, isNotificationsProcessed]) // Index for finding events that need notification processing
  @@index([isHidden, racePromoterId], map: "race_event_hidden_promoter_idx")
  @@index([trackId])
}

/// Per Trackside raceinfo.aspx day/tab (`t`) for a grass roots race event. Parent for race-order rows.
model TracksideRaceInfo {
  id                      String    @id @default(cuid())
  raceEventId             String
  scoringSystemTrackDayId String /// Trackside `t` query param (e.g. "1", "2")
  dayLabel                String?
  calendarDate            DateTime? /// Parsed calendar day for this tab when available (for "race today" matching)
  fetchedAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  payload                 Json?

  RaceEvent                 RaceEvent                 @relation(fields: [raceEventId], references: [id], onDelete: Cascade)
  TracksideRaceOrderEntries TracksideRaceOrderEntry[]

  @@unique([raceEventId, scoringSystemTrackDayId])
  @@index([raceEventId])
  @@index([calendarDate])
}

/// One row per rider/class slot in a race (from race order + entry list). `riderId` resolved at scrape time when possible.
model TracksideRaceOrderEntry {
  id                        String  @id @default(cuid())
  tracksideRaceInfoId       String
  raceNumber                Int
  scoringSystemEventClassId String
  className                 String
  promoterRiderId           String
  riderId                   String?
  sortOrder                 Int     @default(0)

  TracksideRaceInfo TracksideRaceInfo @relation(fields: [tracksideRaceInfoId], references: [id], onDelete: Cascade)
  RiderId           RiderId?          @relation(fields: [riderId], references: [id], onDelete: SetNull)

  @@index([tracksideRaceInfoId])
  @@index([riderId])
  @@index([promoterRiderId])
}

model Photographer {
  id                                  String                                  @id @default(cuid())
  name                                String
  photoUrl                            String?
  coverPhotoUrl                       String?
  activePhotoPersonalLicenseProductId String?
  bio                                 String?
  website                             String?
  email                               String?
  instagramUsername                   String?
  tiktokUsername                      String?
  youtubeUsername                     String?
  facebookUsername                    String?
  createdAt                           DateTime                                @default(now())
  updatedAt                           DateTime                                @updatedAt
  PhotoGalleries                      RaceEventPhotoGallery[]
  RaceEventClassPhotos                RaceEventClassPhoto[]
  TrackPhotos                         TrackPhoto[]
  TrackPhotoTaggedRiders              TrackPhotoTaggedRider[]
  PhotoLicensePurchases               PhotoLicensePurchase[]
  PhotoLicensePurchaseIntents         PhotoLicensePurchaseIntent[]
  RiderIdPhotos                       RiderIdPhoto[]
  UpcomingAttendances                 PhotographerRaceEventSignupAttendance[]
  PhotographerAdmins                  PhotographerAdmin[]
  followers                           PhotographerFollower[]                  @relation("PhotographerFollowedBy")
  users                               User[]

  @@index([name])
}

// Maps users to photographers they can administrate
model PhotographerAdmin {
  id             String   @id @default(cuid())
  userId         String
  photographerId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  photographer Photographer @relation(fields: [photographerId], references: [id], onDelete: Cascade)

  @@unique([userId, photographerId])
  @@index([userId])
  @@index([photographerId])
  @@map("PhotographerAdmins")
}

model RaceEventPhotoGallery {
  id             String       @id @default(cuid())
  title          String
  photoUrl       String
  linkUrl        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  RaceEvent      RaceEvent    @relation(fields: [raceEventId], references: [id], onDelete: Cascade)
  raceEventId    String
  Photographer   Photographer @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  photographerId String

  @@index([raceEventId])
  @@index([photographerId])
  @@index([createdAt])
}

model RaceEventClass {
  id                                  String                              @id @default(cuid())
  name                                String
  date                                DateTime
  scoringSystemEventClassId           String
  score                               Float?
  // Metadata tracking
  hasMetadata                         Boolean                             @default(false)
  // Metadata fields
  engineSize                          String?
  bikeSize                            String?
  isWomens                            Boolean?
  skillLevel                          String?
  ageRange                            String?
  RaceEventClassResults               RaceEventClassResult[]
  RaceEventClassPhotos                RaceEventClassPhoto[]
  RaceSeriesEvents                    RaceSeriesEvent[]
  RaceEvent                           RaceEvent                           @relation(fields: [raceEventId], references: [id], onDelete: Cascade)
  raceEventId                         String
  FantasyContests                     FantasyContest[]
  FantasyEntries                      FantasyEntry[]
  GiveawayCampaignEligibleRaceClasses GiveawayCampaignEligibleRaceClass[]

  @@index([id])
  @@index([score, id], map: "race_event_class_score_id_idx")
  @@index([raceEventId])
  @@index([date(sort: Desc), id], map: "rec_date_id_idx")
}

model RaceEventClassResult {
  id                      String         @id @default(cuid())
  name                    String
  location                String
  riderNumber             String
  manufacturer            String
  overallPosition         String?
  overallPositionNumber   Int?
  heat                    String?
  heatPosition            String?
  heatPostionNumber       Int?
  semi                    String?
  semiPosition            String?
  semiPostionNumber       Int?
  motoOnePosition         String?
  motoOnePositionNumber   Int?
  motoTwoPosition         String?
  motoTwoPositionNumber   Int?
  motoThreePosition       String?
  motoThreePositionNumber Int?
  promoterRiderId         String?
  amaNumber               String?
  score                   Float?
  Laptimes                RaceLaptime[]
  RaceEventClass          RaceEventClass @relation(fields: [raceEventClassId], references: [id], onDelete: Cascade)
  raceEventClassId        String
  RiderId                 RiderId?       @relation(fields: [riderId], references: [id])
  riderId                 String?

  @@index(fields: [raceEventClassId])
  @@index([score, id], map: "rece_result_score_id_idx")
  @@index(fields: [name])
  @@index(fields: [riderId])
  @@index([raceEventClassId, id])
  @@index([raceEventClassId, overallPositionNumber], map: "rece_result_class_overall_idx")
  @@index([riderId, raceEventClassId])
  @@index([riderId, overallPositionNumber], map: "rece_result_rider_position_idx")
  @@index([raceEventClassId, riderId, overallPositionNumber], map: "rece_result_class_rider_idx")
}

model RaceEventClassPhoto {
  id                          String                       @id @default(cuid())
  raceEventId                 String
  raceEventClassId            String
  contentCreatorId            String
  originalFilename            String?
  photoUrl                    String
  thumbnailUrl                String
  status                      String                       @default("uploaded")
  photoMetadata               Json?
  analyzationMetadata         Json?
  brandMetadata               Json?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  RaceEvent                   RaceEvent                    @relation(fields: [raceEventId], references: [id], onDelete: Cascade)
  RaceEventClass              RaceEventClass               @relation(fields: [raceEventClassId], references: [id], onDelete: Cascade)
  ContentCreator              Photographer                 @relation(fields: [contentCreatorId], references: [id], onDelete: Cascade)
  PhotoLicensePurchases       PhotoLicensePurchase[]
  PhotoLicensePurchaseIntents PhotoLicensePurchaseIntent[]
  RiderIdPhotos               RiderIdPhoto[]

  @@index([raceEventId, raceEventClassId])
  @@index([raceEventClassId, createdAt])
  @@index([status])
  @@index([contentCreatorId, createdAt])
  @@map("RaceEventClassPhotos")
}

model RiderIdPhoto {
  id                    String              @id @default(cuid())
  riderId               String
  contentCreatorId      String
  raceEventClassPhotoId String
  assignmentMetadata    Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  RiderId               RiderId             @relation(fields: [riderId], references: [id], onDelete: Cascade)
  ContentCreator        Photographer        @relation(fields: [contentCreatorId], references: [id], onDelete: Cascade)
  RaceEventClassPhoto   RaceEventClassPhoto @relation(fields: [raceEventClassPhotoId], references: [id], onDelete: Cascade)

  @@index([riderId])
  @@index([contentCreatorId, createdAt])
  @@index([raceEventClassPhotoId])
  @@map("RiderIdPhotos")
}

model TrackPhoto {
  id                          String                       @id @default(cuid())
  trackId                     String
  contentCreatorId            String
  photoDate                   DateTime                     @db.Date
  originalFilename            String?
  photoUrl                    String
  thumbnailUrl                String
  photoMetadata               Json?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  Track                       Track                        @relation(fields: [trackId], references: [id], onDelete: Cascade)
  ContentCreator              Photographer                 @relation(fields: [contentCreatorId], references: [id], onDelete: Cascade)
  TaggedRiders                TrackPhotoTaggedRider[]
  PhotoLicensePurchases       PhotoLicensePurchase[]
  PhotoLicensePurchaseIntents PhotoLicensePurchaseIntent[]

  @@index([trackId, photoDate])
  @@index([contentCreatorId, createdAt])
  @@map("TrackPhotos")
}

model TrackPhotoTaggedRider {
  id               String       @id @default(cuid())
  trackPhotoId     String
  riderId          String
  contentCreatorId String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  TrackPhoto       TrackPhoto   @relation(fields: [trackPhotoId], references: [id], onDelete: Cascade)
  RiderId          RiderId      @relation(fields: [riderId], references: [id], onDelete: Cascade)
  ContentCreator   Photographer @relation(fields: [contentCreatorId], references: [id], onDelete: Cascade)

  @@unique([trackPhotoId, riderId])
  @@index([riderId])
  @@index([trackPhotoId])
  @@map("TrackPhotoTaggedRiders")
}

model PhotoLicensePurchaseIntent {
  id                    String                 @id @default(cuid())
  token                 String                 @unique
  userId                String
  raceEventClassPhotoId String?
  trackPhotoId          String?
  contentCreatorId      String
  productId             String
  pricingTierId         String?
  beneficiaryRiderId    String?
  expiresAt             DateTime
  consumedAt            DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  User                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  RaceEventClassPhoto   RaceEventClassPhoto?   @relation(fields: [raceEventClassPhotoId], references: [id], onDelete: Cascade)
  TrackPhoto            TrackPhoto?            @relation(fields: [trackPhotoId], references: [id], onDelete: Cascade)
  ContentCreator        Photographer           @relation(fields: [contentCreatorId], references: [id], onDelete: Cascade)
  BeneficiaryRider      RiderId?               @relation("PhotoLicenseIntentBeneficiary", fields: [beneficiaryRiderId], references: [id], onDelete: SetNull)
  Purchases             PhotoLicensePurchase[]

  @@index([userId, createdAt])
  @@index([raceEventClassPhotoId, createdAt])
  @@index([trackPhotoId, createdAt])
  @@index([contentCreatorId, createdAt])
  @@index([beneficiaryRiderId])
  @@index([expiresAt])
}

model PhotoLicensePurchase {
  id                              String                      @id @default(cuid())
  userId                          String
  raceEventClassPhotoId           String?
  trackPhotoId                    String?
  contentCreatorId                String
  purchaseIntentId                String?
  beneficiaryRiderId              String?
  revenueCatTransactionId         String                      @unique
  revenueCatOriginalTransactionId String?
  revenueCatEventType             String?
  store                           String?
  productId                       String
  pricingTierId                   String?
  currencyCode                    String?
  amountPaidCents                 Int
  storeFeeCents                   Int
  platformFeeCents                Int
  contentCreatorPayoutCents       Int
  purchasedAt                     DateTime
  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt
  rawRevenueCatPayload            Json?
  User                            User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  RaceEventClassPhoto             RaceEventClassPhoto?        @relation(fields: [raceEventClassPhotoId], references: [id], onDelete: Cascade)
  TrackPhoto                      TrackPhoto?                 @relation(fields: [trackPhotoId], references: [id], onDelete: Cascade)
  ContentCreator                  Photographer                @relation(fields: [contentCreatorId], references: [id], onDelete: Cascade)
  PurchaseIntent                  PhotoLicensePurchaseIntent? @relation(fields: [purchaseIntentId], references: [id], onDelete: SetNull)
  BeneficiaryRider                RiderId?                    @relation("PhotoLicensePurchaseBeneficiary", fields: [beneficiaryRiderId], references: [id], onDelete: SetNull)

  @@index([raceEventClassPhotoId, purchasedAt])
  @@index([trackPhotoId, purchasedAt])
  @@index([contentCreatorId, purchasedAt])
  @@index([beneficiaryRiderId, purchasedAt])
}

model RaceSeries {
  id                String            @id @default(cuid())
  name              String
  promoterSeriesId  String
  seriesUrl         String
  roundsCount       Int?
  lastEventDate     DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  RacePromoter      RacePromoter      @relation(fields: [racePromoterId], references: [id])
  racePromoterId    String
  RaceSeriesClasses RaceSeriesClass[]
  RaceSeriesEvents  RaceSeriesEvent[]

  @@unique([racePromoterId, promoterSeriesId])
  @@index([racePromoterId])
  @@map("RaceSeries")
}

model RaceSeriesClass {
  id                     String                  @id @default(cuid())
  name                   String
  promoterSeriesClassId  String
  classUrl               String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  RaceSeries             RaceSeries              @relation(fields: [raceSeriesId], references: [id], onDelete: Cascade)
  raceSeriesId           String
  RaceSeriesClassResults RaceSeriesClassResult[]
  RaceSeriesEvents       RaceSeriesEvent[]
  RiderId                RiderId?                @relation(fields: [riderId], references: [id])
  riderId                String?

  @@unique([raceSeriesId, promoterSeriesClassId])
  @@index([raceSeriesId])
  @@index([riderId])
  @@map("RaceSeriesClasses")
}

model RaceSeriesClassResult {
  id                    String          @id @default(cuid())
  name                  String
  location              String?
  riderNumber           String?
  manufacturer          String?
  overallPosition       String?
  overallPositionNumber Int?
  totalPoints           Int?
  promoterRiderId       String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  RaceSeriesClass       RaceSeriesClass @relation(fields: [raceSeriesClassId], references: [id], onDelete: Cascade)
  raceSeriesClassId     String
  RiderId               RiderId?        @relation(fields: [riderId], references: [id])
  riderId               String?

  @@unique([raceSeriesClassId, promoterRiderId])
  @@index([raceSeriesClassId])
  @@index([riderId])
  @@map("RaceSeriesClassResults")
}

model RaceSeriesEvent {
  id                String          @id @default(cuid())
  raceSeriesId      String
  raceSeriesClassId String
  raceEventId       String
  raceEventClassId  String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  RaceSeries        RaceSeries      @relation(fields: [raceSeriesId], references: [id], onDelete: Cascade)
  RaceSeriesClass   RaceSeriesClass @relation(fields: [raceSeriesClassId], references: [id], onDelete: Cascade)
  RaceEvent         RaceEvent       @relation(fields: [raceEventId], references: [id], onDelete: Cascade)
  RaceEventClass    RaceEventClass  @relation(fields: [raceEventClassId], references: [id], onDelete: Cascade)

  @@unique([raceSeriesClassId, raceEventClassId])
  @@index([raceSeriesId])
  @@index([raceSeriesClassId])
  @@index([raceEventId])
  @@index([raceEventClassId])
  @@map("RaceSeriesEvents")
}

model RaceLaptime {
  id                     String               @id @default(cuid())
  motoId                 String
  motoTypeId             String
  lapNumber              Int
  laptime                String
  gap                    String
  diff                   String
  position               String
  positionNumber         Int?
  isPersonalFastestLap   Boolean
  isRaceFastestLap       Boolean
  RaceEventClassResult   RaceEventClassResult @relation(fields: [raceEventClassResultId], references: [id], onDelete: Cascade)
  raceEventClassResultId String

  @@unique([raceEventClassResultId, motoTypeId, motoId, lapNumber])
  @@index([raceEventClassResultId, positionNumber], map: "race_laptimes_result_position_idx")
}

model OffroadRaceEvent {
  id                      String                  @id @default(cuid())
  name                    String
  date                    DateTime
  endDate                 DateTime? // End date for multi-day events
  location                String
  city                    String                  @default("")
  state                   String                  @default("")
  latitude                Float?
  longitude               Float?
  isGeoCoded              Boolean                 @default(false)
  isHidden                Boolean                 @default(false)
  eventUrl                String
  scoringSystemEventId    String
  seriesId                String? // Series ID from external system
  seriesName              String? // Series name (e.g., "2024 WORCS")
  scoringTier             String                  @default("1")
  score                   Float?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  RacePromoter            RacePromoter            @relation(fields: [racePromoterId], references: [id])
  racePromoterId          String
  OffroadRaceEventClasses OffroadRaceEventClass[]

  @@index([id])
  @@index([racePromoterId])
  @@index([isHidden, racePromoterId])
  @@map("OffroadRaceEvents")
}

model OffroadRaceEventClass {
  id                           String                        @id @default(cuid())
  name                         String
  date                         DateTime
  scoringSystemEventClassId    String
  classTypeId                  String? // Class type ID (e.g., "2" for WORCS MC)
  classTypeName                String? // Class type name (e.g., "WORCS MC", "WORCS ATV")
  score                        Float?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  OffroadRaceEventClassResults OffroadRaceEventClassResult[]
  OffroadRaceEvent             OffroadRaceEvent              @relation(fields: [offroadRaceEventId], references: [id], onDelete: Cascade)
  offroadRaceEventId           String

  @@index([id])
  @@index([offroadRaceEventId])
  @@map("OffroadRaceEventClasses")
}

model OffroadRaceEventClassResult {
  id                      String                @id @default(cuid())
  place                   String // Position in class (e.g., "1", "2", "DNF")
  placeNumber             Int? // Numeric position in class
  overallPosition         String? // Overall position across all classes (e.g., "8", "DNF")
  overallPositionNumber   Int? // Numeric overall position
  pointsEarned            Int? // Points earned for this result
  fastestLap              String? // Fastest lap time (e.g., "08:38.166")
  fastestLapLapNumber     Int? // Lap number of fastest lap
  laps                    Int? // Number of laps completed
  elapsedTime             String? // Total elapsed time (e.g., "00:36:06.388")
  riderNumber             String
  riderName               String
  promoterRiderId         String? // External rider ID from promoter system
  manufacturer            String
  location                String
  score                   Float?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  OffroadRaceLaptimes     OffroadRaceLaptime[]
  OffroadRaceEventClass   OffroadRaceEventClass @relation(fields: [offroadRaceEventClassId], references: [id], onDelete: Cascade)
  offroadRaceEventClassId String
  RiderId                 RiderId?              @relation(fields: [riderId], references: [id])
  riderId                 String?

  @@index([offroadRaceEventClassId])
  @@index([riderName])
  @@index([riderId])
  @@index([promoterRiderId])
  @@index([offroadRaceEventClassId, id])
  @@index([riderId, offroadRaceEventClassId])
  @@map("OffroadRaceEventClassResults")
}

model OffroadRaceLaptime {
  id                            String                      @id @default(cuid())
  lapNumber                     Int
  lapTime                       String // Lap time (e.g., "07:15.817")
  timeBehind                    String? // Time behind leader (e.g., "00:02.018")
  positionInLap                 Int? // Position during that lap
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime                    @updatedAt
  OffroadRaceEventClassResult   OffroadRaceEventClassResult @relation(fields: [offroadRaceEventClassResultId], references: [id], onDelete: Cascade)
  offroadRaceEventClassResultId String

  @@unique([offroadRaceEventClassResultId, lapNumber])
  @@index([offroadRaceEventClassResultId])
  @@index([offroadRaceEventClassResultId, positionInLap], map: "offroad_race_laptimes_result_position_idx")
  @@map("OffroadRaceLaptimes")
}

model User {
  id                              String                          @id @default(cuid())
  authId                          String?                         @unique
  email                           String?
  firstName                       String?
  lastName                        String?
  fullName                        String?
  forgotPasswordCode              String?
  forgotPasswordLockoutCount      Int                             @default(0)
  pushNotificationsEnabled        Boolean                         @default(false)
  isDeleted                       Boolean                         @default(false)
  isAdmin                         Boolean                         @default(false)
  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt
  // RevenueCat subscription fields
  revenueCatAppUserId             String?                         @unique
  subscriptionStatus              String? // 'active', 'expired', 'cancelled', 'billing_issue', null
  subscriptionTier                String? // 'pro', 'premium', etc.
  subscriptionExpiresAt           DateTime?
  subscriptionProductId           String? // RevenueCat product identifier
  subscriptionUpdatedAt           DateTime? // Last time subscription was updated from webhook
  /// Set when the user has an active Prospect Fan Pass (RevenueCat / webhook); used for fan lap notifications.
  fanPassExpiresAt                DateTime?
  UserPushNotificationTokens      UserPushNotificationTokens[]
  UserLiveActivityTokens          UserLiveActivityTokens[]
  UserFutureEventNotifications    UserFutureEventNotification[]
  RiderNotifications              UserRiderNotification[]
  UserNotifications               UserNotification[]
  UserPushNotificationPreference  UserPushNotificationPreference?
  Following                       Follower[]                      @relation("UserFollowing")
  PhotographerFollowing           PhotographerFollower[]          @relation("UserFollowingPhotographer")
  Riders                          RiderId[]
  TracksShredded                  UserTrackShredded[]
  FavoriteTracks                  UserTrackFavorited[]
  TracksAdmin                     TrackAdmin[]
  TrackPracticeSessionRsvps       UserTrackPracticeSessionRsvp[]
  IncentiveRedemptions            IncentiveRedemption[]
  UserIncentives                  UserIncentive[]
  AdOrders                        AdOrder[]
  Vehicles                        Vehicle[]
  VehicleMaintenanceLogs          VehicleMaintenanceLog[]
  VehicleSuspensionLogs           VehicleSuspensionLog[]
  BrandAdmins                     BrandAdmin[]
  TrainingFacilityAdmins          TrainingFacilityAdmin[]
  PhotographerAdmins              PhotographerAdmin[]
  PhotoLicensePurchases           PhotoLicensePurchase[]
  PhotoLicensePurchaseIntents     PhotoLicensePurchaseIntent[]
  AffiliateCode                   AffiliateCode?                  @relation(fields: [affiliateCodeId], references: [id])
  affiliateCodeId                 String?
  Photographer                    Photographer?                   @relation(fields: [photographerId], references: [id])
  photographerId                  String?
  /// Public fantasy identity (leaderboards, groups). Not the same as social handles elsewhere.
  username                        String?                         @unique
  /// US state code or label for display / state rankings context
  displayState                    String?
  /// fan | parent | rider
