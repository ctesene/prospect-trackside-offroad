  createdAt                     DateTime                   @default(now())
  qualifierClassId              String
  AreaQualifierClass            LorettasAreaQualifierClass @relation(fields: [qualifierClassId], references: [id], onDelete: Cascade)

  @@index([riderId, overallNumber], map: "lorettas_area_qualifier_result_rider_overall_idx")
  @@index([score, id], map: "lorettas_area_result_score_id_idx")
  @@index([qualifierClassId, overallNumber], map: "lorettas_area_result_class_overall_idx")
  @@index([riderId, qualifierClassId], map: "lorettas_area_result_rider_class_idx")
}

model LorettasRegionalQualifiers {
  id                               String                           @id @default(cuid())
  region                           String
  track                            String
  url                              String
  year                             Int
  date                             DateTime
  location                         String
  createdAt                        DateTime                         @default(now())
  LorettasRegionalQualifierClasses LorettasRegionalQualifierClass[]
}

model LorettasRegionalQualifierClass {
  id                String                            @id @default(cuid())
  name              String
  url               String
  year              Int
  createdAt         DateTime                          @default(now())
  qualifierId       String
  RegionalQualifier LorettasRegionalQualifiers        @relation(fields: [qualifierId], references: [id], onDelete: Cascade)
  Results           LorettasRegionalQualifierResult[]

  @@index([year], map: "lorettas_regional_class_year_idx")
}

model LorettasRegionalQualifierResult {
  id                     String                         @id @default(cuid())
  name                   String
  overall                String
  overallNumber          Int?
  score                  Int?
  location               String
  city                   String?
  state                  String?
  motoOne                String
  motoTwo                String
  motoThree              String?
  raceNumber             String
  powerRanking           String
  numberOfEntries        String
  numberOfRiders         String
  isQualified            Boolean                        @default(false)
  isPaid                 Boolean                        @default(false)
  riderId                String?
  promoterRiderId        String
  createdAt              DateTime                       @default(now())
  qualifierClassId       String
  RegionalQualifierClass LorettasRegionalQualifierClass @relation(fields: [qualifierClassId], references: [id], onDelete: Cascade)

  @@index([riderId, overallNumber], map: "lorettas_regional_qualifier_result_rider_overall_idx")
  @@index([score, id], map: "lorettas_regional_result_score_id_idx")
  @@index([qualifierClassId, overallNumber], map: "lorettas_regional_result_class_overall_idx")
  @@index([riderId, qualifierClassId], map: "lorettas_regional_result_rider_class_idx")
}

model NewsFeed {
  id             String         @id @default(cuid())
  feedUrl        String
  isActive       Boolean        @default(true)
  name           String
  imageUrl       String         @default("")
  webUrl         String         @default("")
  headerImageUrl String?
  NewsFeedItems  NewsFeedItem[]
}

model NewsFeedItem {
  id            String                   @id @default(cuid())
  title         String
  link          String
  description   String
  pubDate       DateTime
  author        String
  guid          String                   @unique
  image         String?
  displayType   String                   @default("regular") // "expanded", "regular", or "condensed"
  isImageHidden Boolean                  @default(false)
  newsFeedId    String
  NewsFeed      NewsFeed                 @relation(fields: [newsFeedId], references: [id], onDelete: Cascade)
  Content       Content[]
  Categories    NewsFeedItemToCategory[]
  Tracks        NewsFeedItemToTrack[]
  Riders        NewsFeedItemToRider[]
  Events        NewsFeedItemToEvent[]

  @@index([newsFeedId])
  @@index([pubDate])
  @@index([pubDate(sort: Desc), id(sort: Desc)], map: "news_feed_item_pub_date_id_idx")
}

model NewsFeedItemCategory {
  id        String                   @id @default(cuid())
  title     String
  sortOrder Int
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  items     NewsFeedItemToCategory[]

  @@unique([sortOrder])
}

model NewsFeedItemToCategory {
  newsFeedItemId         String
  newsFeedItemCategoryId String
  createdAt              DateTime @default(now())

  newsFeedItem         NewsFeedItem         @relation(fields: [newsFeedItemId], references: [id], onDelete: Cascade)
  newsFeedItemCategory NewsFeedItemCategory @relation(fields: [newsFeedItemCategoryId], references: [id], onDelete: Cascade)

  @@id([newsFeedItemId, newsFeedItemCategoryId])
  @@index([newsFeedItemId])
  @@index([newsFeedItemCategoryId])
}

model ContentCategory {
  id        String              @id @default(cuid())
  title     String
  sortOrder Int
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  contents  ContentToCategory[]

  @@unique([sortOrder])
}

model Content {
  id             String   @id @default(cuid())
  sortOrder      Int
  position       String // e.g., 'homepage', 'top-stories', etc.
  newsFeedItemId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  NewsFeedItem NewsFeedItem?       @relation(fields: [newsFeedItemId], references: [id], onDelete: Cascade)
  categories   ContentToCategory[]

  @@unique([position, sortOrder]) // Ensure no duplicate sort orders within a position
  @@index([newsFeedItemId])
}

model ContentToCategory {
  contentId         String
  contentCategoryId String
  createdAt         DateTime @default(now())

  content  Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  category ContentCategory @relation(fields: [contentCategoryId], references: [id], onDelete: Cascade)

  @@id([contentId, contentCategoryId])
  @@index([contentId])
  @@index([contentCategoryId])
}

// New join tables for NewsFeedItem relationships
model NewsFeedItemToTrack {
  newsFeedItemId String
  trackId        String
  createdAt      DateTime @default(now())

  newsFeedItem NewsFeedItem @relation(fields: [newsFeedItemId], references: [id], onDelete: Cascade)
  track        Track        @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([newsFeedItemId, trackId])
  @@index([newsFeedItemId])
  @@index([trackId])
}

model NewsFeedItemToRider {
  newsFeedItemId String
  riderId        String
  createdAt      DateTime @default(now())

  newsFeedItem NewsFeedItem @relation(fields: [newsFeedItemId], references: [id], onDelete: Cascade)
  rider        RiderId      @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@id([newsFeedItemId, riderId])
  @@index([newsFeedItemId])
  @@index([riderId])
}

model NewsFeedItemToEvent {
  newsFeedItemId String
  eventId        String
  createdAt      DateTime @default(now())

  newsFeedItem NewsFeedItem @relation(fields: [newsFeedItemId], references: [id], onDelete: Cascade)
  event        RaceEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([newsFeedItemId, eventId])
  @@index([newsFeedItemId])
  @@index([eventId])
}

// Incentive System Models
model Incentive {
  id                    String                @id @default(cuid())
  title                 String
  description           String?
  callToAction          String?
  redemptionDescription String?
  incentiveType         IncentiveType         @default(MOTOSPORT_CODE)
  value                 String? // For codes, this might be "20% off", for cash "$10", etc.
  maxRedemptions        Int? // null means unlimited
  currentRedemptions    Int                   @default(0)
  startDate             DateTime?
  endDate               DateTime?
  isActive              Boolean               @default(true)
  brandId               String
  brand                 CrmBrand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  codes                 IncentiveCode[]
  redemptions           IncentiveRedemption[]
  rules                 Json? // Type-specific rules. RESULT_TO_QR_CODE: { "promoterIds": ["id1", "id2", ...] }
  userIncentives        UserIncentive[]
  riderIncentives       RiderIncentive[]

  @@index([brandId])
  @@index([isActive])
  @@index([startDate, endDate])
}

model IncentiveCode {
  id          String               @id @default(cuid())
  code        String               @unique // The actual code (e.g., "MOTO20OFF")
  isRedeemed  Boolean              @default(false)
  redeemedAt  DateTime?
  redeemedBy  String? // User ID who redeemed it
  incentiveId String
  incentive   Incentive            @relation(fields: [incentiveId], references: [id], onDelete: Cascade)
  redemption  IncentiveRedemption?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([incentiveId])
  @@index([isRedeemed])
  @@index([code])
}

model IncentiveRedemption {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  incentiveId      String
  incentive        Incentive     @relation(fields: [incentiveId], references: [id], onDelete: Cascade)
  codeId           String        @unique
  code             IncentiveCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  redeemedAt       DateTime      @default(now())
  /// For RESULT_TO_QR_CODE: set when the dealer completes redemption on the public /incentives/[id] page (code revealed).
  dealerRedeemedAt DateTime?
  expiresAt        DateTime? // When the redemption expires
  isExpired        Boolean       @default(false)
  notes            String? // Any admin notes
  riderIncentive   RiderIncentive?

  @@index([userId])
  @@index([incentiveId])
  @@index([redeemedAt])
  @@index([isExpired])
  @@index([dealerRedeemedAt])
}

enum IncentiveType {
  MOTOSPORT_CODE
  RESULT_TO_QR_CODE
  CASH_REBATE
  GIFT_CARD
  DISCOUNT_CODE
  FREE_SHIPPING
  PRODUCT_GIVEAWAY
}

model UserIncentive {
  id          String   @id @default(cuid())
  userId      String
  incentiveId String
  reason      String // Human-readable: "account signup", "raced at {event name}", etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  incentive Incentive @relation(fields: [incentiveId], references: [id], onDelete: Cascade)

  @@unique([userId, incentiveId, reason])
  @@index([userId])
  @@index([incentiveId])
}

/// Same eligibility semantics as UserIncentive, but granted to a RiderId (e.g. brand deal tied to the athlete). Any user who has claimed that rider sees it in inbox / can redeem.
model RiderIncentive {
  id           String               @id @default(cuid())
  riderId      String
  incentiveId  String
  reason       String
  /// When admin assigns a code-based incentive, redemption is created immediately and linked here.
  redemptionId String?              @unique
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  rider      RiderId              @relation(fields: [riderId], references: [id], onDelete: Cascade)
  incentive  Incentive            @relation(fields: [incentiveId], references: [id], onDelete: Cascade)
  redemption IncentiveRedemption? @relation(fields: [redemptionId], references: [id], onDelete: SetNull)

  @@unique([riderId, incentiveId, reason])
  @@index([riderId])
  @@index([incentiveId])
}

model Manufacturer {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique // URL-friendly version (e.g., "honda", "yamaha")
  logoUrl   String?
  website   String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  models    VehicleModel[]
  vehicles  Vehicle[]

  @@index([name])
  @@index([slug])
  @@index([isActive])
}

model VehicleModel {
  id             String             @id @default(cuid())
  manufacturerId String
  manufacturer   Manufacturer       @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  name           String // Model name (e.g., "CRF450R", "YZ250F")
  category       String? // e.g., "Dirt Bike", "ATV", "UTV", "Street"
  engine         String? // Engine size/type (e.g., "450cc", "250cc 2-stroke")
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  modelYears     VehicleModelYear[]
  vehicles       Vehicle[]

  @@unique([manufacturerId, name]) // Prevent duplicate models per manufacturer
  @@index([manufacturerId])
  @@index([name])
  @@index([category])
}

model VehicleModelYear {
  id              String       @id @default(cuid())
  vehicleModelId  String
  vehicleModel    VehicleModel @relation(fields: [vehicleModelId], references: [id], onDelete: Cascade)
  year            Int
  ownersManualUrl String? // URL to the owner's manual for this specific year
  motosportPartsUrl String? // MotoSport OEM parts fiche URL for this year/model
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  vehicles        Vehicle[]

  @@unique([vehicleModelId, year]) // Prevent duplicate years per model
  @@index([vehicleModelId])
  @@index([year])
  @@index([isActive])
}

model Vehicle {
  id                 String                  @id @default(cuid())
  userId             String
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String // User's custom name for the vehicle
  manufacturerId     String? // Optional reference to manufacturer table
  manufacturer       Manufacturer?           @relation(fields: [manufacturerId], references: [id])
  vehicleModelId     String? // Optional reference to model table
  vehicleModel       VehicleModel?           @relation(fields: [vehicleModelId], references: [id])
  vehicleModelYearId String? // Optional reference to specific model year
  vehicleModelYear   VehicleModelYear?       @relation(fields: [vehicleModelYearId], references: [id])
  vin                String?
  purchaseDate       String?
  purchasePrice      Float?
  photoUrl           String?
  currentHours       Float?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  maintenanceLogs    VehicleMaintenanceLog[]
  suspensionLogs     VehicleSuspensionLog[]

  @@index([userId])
  @@index([manufacturerId])
  @@index([vehicleModelId])
  @@index([vehicleModelYearId])
}

model VehicleMaintenanceLog {
  id             String   @id @default(cuid())
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId         String // Denormalized for easier querying
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description    String // Description of the maintenance performed
  serviceDate    DateTime // When the service was performed
  hoursAtService Float? // Vehicle hours at time of service
  cost           Float? // Optional cost of the service
  notes          String? // Optional additional notes
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([vehicleId])
  @@index([userId])
  @@index([serviceDate])
  @@index([vehicleId, serviceDate])
}

model VehicleSuspensionLog {
  id                               String   @id @default(cuid())
  vehicleId                        String
  vehicle                          Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId                           String
  user                             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ridingLocation                   String
  logDate                          DateTime
  frontCompressionClicksOut        Int
  frontReboundClicksOut            Int
  frontPsiOrSpringRate             String?
  frontForkHeightMm                Float
  rearHighSpeedCompressionTurnsOut Float
  rearLowSpeedCompressionClicksOut Int
  rearReboundClicksOut             Int
  rearSagMm                        Float
  feeling                          String?
  trackDescription                 String?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  @@index([vehicleId])
  @@index([userId])
  @@index([logDate])
  @@index([vehicleId, logDate])
}

model AdLocation {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Float
  dimensions  String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      AdOrder[]

  @@index([isActive])
}

model AdOrder {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  adLocationId    String
  adLocation      AdLocation    @relation(fields: [adLocationId], references: [id])
  duration        Int // Number of days
  budget          Float // Daily budget
  totalCost       Float
  artworkUrl      String?
  isPaid          Boolean       @default(false)
  isActive        Boolean       @default(false)
  startDate       DateTime?
  endDate         DateTime?
  stripePaymentId String?
  googleAdsId     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  targetCities    AdOrderCity[]

  @@index([userId])
  @@index([isPaid])
  @@index([isActive])
  @@index([startDate, endDate])
}

model AdOrderCity {
  id        String   @id @default(cuid())
  adOrderId String
  adOrder   AdOrder  @relation(fields: [adOrderId], references: [id], onDelete: Cascade)
  city      String
  state     String?
  createdAt DateTime @default(now())

  @@index([adOrderId])
}

model InstagramProfile {
  id String @id @default(cuid())

  // Instagram account details
  instagramId     String  @unique // Instagram's internal ID
  username        String  @unique // Instagram username
  fullName        String?
  biography       String?
  profileImageUrl String?
  profileUrl      String?
  externalUrl     String?

  // Account stats
  followers       Int    @default(0)
  following       Int    @default(0)
  postsCount      Int    @default(0)
  highlightsCount Int    @default(0)
  avgEngagement   Float?

  // Engagement metrics from last 10 posts
  postsInLast10       Int    @default(0) // Total posts in sample (up to 10)
  totalLikesLast10    Int    @default(0) // Sum of likes from last 10 posts
  totalCommentsLast10 Int    @default(0) // Sum of comments from last 10 posts
  avgLikesPerPost     Float? // Average likes per post in sample
  avgCommentsPerPost  Float? // Average comments per post in sample

  // Posting frequency metrics
  daysSinceLastPost   Int? // Days since most recent post
  daysSince10thPost   Int? // Days since 10th most recent post (if available)
  avgDaysBetweenPosts Float? // Average days between posts in sample
  postingFrequency    Float? // Posts per week based on sample

  // Engagement quality metrics
  engagementRate       Float? // (likes + comments) / followers
  likesToCommentsRatio Float? // likes / comments ratio
  bestPostLikes        Int? // Highest likes count in sample
  bestPostComments     Int? // Highest comments count in sample

  // Account type flags
  isBusinessAccount     Boolean @default(false)
  isProfessionalAccount Boolean @default(false)
  isVerified            Boolean @default(false)
  isPrivate             Boolean @default(false)
  isJoinedRecently      Boolean @default(false)
  hasChannel            Boolean @default(false)

  // Business details
  businessCategoryName String?
  categoryName         String?
  businessAddress      String?
  emailAddress         String?

  // Metadata
  facebookId     String? // fbid from webhook
  partnerId      String? // partner_id from webhook
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastDataUpdate DateTime @default(now())

  // Relations managed manually via instagramProfileId fields
  RiderId          RiderId[]
  Track            Track[]
  CrmBrand         CrmBrand[]
  TrainingFacility TrainingFacility[]
  Posts            InstagramPost[]

  @@index([lastDataUpdate])
}

model InstagramPost {
  id String @id @default(cuid())

  // Post identifiers
  instagramPostId    String           @unique // Instagram's internal post ID
  postUrl            String           @unique // Instagram post URL
  instagramProfileId String
  instagramProfile   InstagramProfile @relation(fields: [instagramProfileId], references: [id], onDelete: Cascade)

  // Post content
  caption     String? // Post caption/description
  contentType String? // "Video", "Image", "Carousel", etc.
  imageUrl    String? // Main image URL
  videoUrl    String? // Video URL if it's a video post

  // Post metrics
  likes    Int @default(0)
  comments Int @default(0)
  shares   Int @default(0) // For video posts
  views    Int @default(0) // For video posts

  // Post metadata
  postDate DateTime // When the post was published
  isPinned Boolean  @default(false)

  // Location data
  locationId   String?
  locationName String?
  locationSlug String?

  // Content analysis - space-delimited strings for easy querying
  hashtags String @default("") // Space-delimited hashtags (e.g., "motocross racing texas")
  mentions String @default("") // Space-delimited mentions (e.g., "teamtesene underground_mx tld_moto")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instagramProfileId])
  @@index([postDate])
  @@index([hashtags]) // For hashtag searches
  @@index([mentions]) // For mention searches
  @@index([likes])
  @@index([contentType])
}

model TikTokProfile {
  id String @id @default(cuid())

  // TikTok account details
  tiktokId          String  @unique // TikTok's internal ID
  username          String  @unique // TikTok username
  nickname          String?
  biography         String?
  profileImageUrl   String?
  profileImageUrlHd String?
  profileUrl        String?

  // Account stats
  followers             Int     @default(0)
  following             Int     @default(0)
  totalLikes            Int     @default(0)
  likeCount             Int     @default(0)
  diggCount             Int     @default(0)
  videosCount           Int     @default(0)
  avgEngagementRate     Float?
  commentEngagementRate Float?
  likeEngagementRate    Float?
  predictedLanguage     String?

  // Engagement metrics from top videos
  videosInLast10      Int    @default(0) // Total videos in sample (up to 10)
  totalLikesLast10    Int    @default(0) // Sum of likes from top videos
  totalCommentsLast10 Int    @default(0) // Sum of comments from top videos
  totalSharesLast10   Int    @default(0) // Sum of shares from top videos
  totalViewsLast10    Int    @default(0) // Sum of views from top videos
  avgLikesPerVideo    Float? // Average likes per video in sample
  avgCommentsPerVideo Float? // Average comments per video in sample
  avgSharesPerVideo   Float? // Average shares per video in sample
  avgViewsPerVideo    Float? // Average views per video in sample

  // Posting frequency metrics
  daysSinceLastVideo   Int? // Days since most recent video
  daysSince10thVideo   Int? // Days since 10th most recent video (if available)
  avgDaysBetweenVideos Float? // Average days between videos in sample
  postingFrequency     Float? // Videos per week based on sample

  // Engagement quality metrics
  engagementRate       Float? // (likes + comments + shares) / followers
  likesToCommentsRatio Float? // likes / comments ratio
  bestVideoLikes       Int? // Highest likes count in sample
  bestVideoComments    Int? // Highest comments count in sample
  bestVideoViews       Int? // Highest views count in sample

  // Account type flags
  isVerified     Boolean @default(false)
  isPrivate      Boolean @default(false)
  isCommerceUser Boolean @default(false)
  isAdVirtual    Boolean @default(false)
  openFavorite   Boolean @default(false)

  // Metadata
  accountCreatedTime DateTime? // When the TikTok account was created
  secuId             String? // TikTok's secu_id
  signature          String? // TikTok signature
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastDataUpdate     DateTime  @default(now())

  // Relations managed manually via tiktokProfileId fields
  RiderId          RiderId[]
  Track            Track[]
  CrmBrand         CrmBrand[]
  TrainingFacility TrainingFacility[]

  @@index([lastDataUpdate])
}

model YouTubeProfile {
  id String @id @default(cuid())

  // YouTube account details
  youtubeId       String  @unique // YouTube's internal ID
  channelId       String? // YouTube channel ID
  username        String  @unique // YouTube username/handle
  channelName     String? // YouTube channel name
  description     String? // Channel description
  profileImageUrl String? // Channel profile image
  bannerImageUrl  String? // Channel banner image
  profileUrl      String? // YouTube channel URL

  // Channel stats
  subscribers Int     @default(0)
  videosCount Int     @default(0)
  totalViews  Int     @default(0)
  location    String? // Channel location
  hasPodcast  Boolean @default(false)
  handleMd5   String? // MD5 hash of handle

  // Engagement metrics from top videos
  videosInLast10   Int    @default(0) // Total videos in sample (up to 10)
  totalViewsLast10 Int    @default(0) // Sum of views from top videos
  avgViewsPerVideo Float? // Average views per video in sample

  // Posting frequency metrics
  daysSinceLastVideo   Int? // Days since most recent video
  daysSince10thVideo   Int? // Days since 10th most recent video (if available)
  avgDaysBetweenVideos Float? // Average days between videos in sample
  postingFrequency     Float? // Videos per week based on sample

  // Engagement quality metrics
  engagementRate Float? // total views / subscribers
  bestVideoViews Int? // Highest views count in sample

  // Channel metadata
  channelCreatedDate DateTime? // When the YouTube channel was created
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastDataUpdate     DateTime  @default(now())

  // Relations managed manually via youtubeProfileId fields
  RiderId          RiderId[]
  Track            Track[]
  CrmBrand         CrmBrand[]
  TrainingFacility TrainingFacility[]

  @@index([lastDataUpdate])
}

// Dead Social Media Profiles - Track profiles that return 404/not found to avoid wasting scraping tokens
model DeadSocialProfile {
  id String @id @default(cuid())

  // Profile identification
  platform          String // "instagram", "tiktok", "youtube"
  profileIdentifier String // Username, handle, or URL identifier
  profileUrl        String? // Full profile URL if available

  // Error information
  errorCode    String? // BrightData error code (e.g., "404", "dead_page")
  errorMessage String? // Full error message from BrightData

  // Tracking
  firstSeenDead DateTime @default(now()) // When we first detected it was dead
  lastChecked   DateTime @default(now()) // Last time we attempted to scrape it
  checkCount    Int      @default(1) // Number of times we've checked if it's still dead

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unique constraint: one entry per platform + profileIdentifier
  @@unique([platform, profileIdentifier])
  @@index([platform, profileIdentifier])
  @@index([platform])
  @@index([firstSeenDead])
  @@map("DeadSocialProfiles")
}

// CRM Models
model Category {
  id             String  @id @default(cuid())
  name           String  @unique
  slug           String  @unique
  description    String?
  color          String  @default("#00abec") // Brand color for UI
  isPublicFacing Boolean @default(true) // Show in mobile app vs CRM-only

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  brands BrandCategory[]

  @@map("categories")
}

model CrmBrand {
  id              String  @id @default(cuid())
  name            String  @unique
  slug            String  @unique
  website         String?
  storeType       String? // e.g., "shopify" - determines how to interact with their store
  logoUrl         String?
  avatarUrl       String? // 320x320 brand avatar image
  coverPhotoUrl   String? // 300x250 brand cover photo
  youtubeVideoUrl String? // Full YouTube video URL for brand overview
  description     String?
  contactName     String?
  email           String?
  phone           String?
  isPublicFacing  Boolean @default(false) // Show in mobile app vs CRM-only

  // Social media usernames (for scraping and display)
  instagramUsername   String?
  instagramProfileId  String?
  lastInstagramUpdate DateTime?
  tiktokUsername      String?
  tiktokProfileId     String?
  lastTiktokUpdate    DateTime?
  youtubeUsername     String?
  youtubeProfileId    String?
  lastYouTubeUpdate   DateTime?
  facebookUsername    String?

  // Social scoring
  socialScore            Float?
  socialScoreLastUpdated DateTime?

  // Feature flags
  isSponsorshipEnabled    Boolean @default(false)
  isRosterEnabled         Boolean @default(false)
  isOfferEnabled          Boolean @default(false)
  isComplianceEnabled     Boolean @default(false)
  isScoutEnabled          Boolean @default(false)
  isAnalyticsEnabled      Boolean @default(false)
  isIntelligenceEnabled   Boolean @default(false)
  isSocialCardsEnabled    Boolean @default(false)
  isCommunicationsEnabled Boolean @default(false)
  isProgramTiersLocked    Boolean @default(true)

  // Discovery flags
  isFeatured   Boolean @default(false)
  isNewlyAdded Boolean @default(false)

  // Company details
  industry     String?
  companySize  String? // "startup", "small", "medium", "enterprise"
  headquarters String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  categories               BrandCategory[]
  deals                    Deal[]
  tiers                    PackageTier[]
  brandPrograms            BrandProgram[]
  brandAdmins              BrandAdmin[]
  brandOffers              BrandOffer[]
  supportedByRiders        RiderSupportedBrand[]
  adWallet                 BrandAdWallet?
  adOrders                 BrandAdOrder[]
  adMonthlyBudget          BrandAdMonthlyBudget?
  adCreatives              BrandAdCreative[]
  featuredPurchases        FeaturedBrandPurchase[]
  budgetAlerts             BrandAdBudgetAlert[]
  adAssets                 BrandAdAsset[]
  upcomingAttendances      BrandRaceEventSignupAttendance[]
  incentives               Incentive[]
  brandRiderMessageThreads BrandRiderMessageThread[]
  dealerBrands             DealerBrand[]
  GiveawayCampaigns        GiveawayCampaign[]
  InstagramProfile         InstagramProfile?                @relation(fields: [instagramProfileId], references: [id])
  TikTokProfile            TikTokProfile?                   @relation(fields: [tiktokProfileId], references: [id])
  YouTubeProfile           YouTubeProfile?                  @relation(fields: [youtubeProfileId], references: [id])

  @@index([instagramUsername])
  @@index([tiktokUsername])
  @@index([youtubeUsername])
  @@map("Brands")
}

/// Retail / powersports dealer location (may carry multiple OEM or apparel brands).
model Dealer {
  id            String  @id @default(cuid())
  name          String
  street        String  @default("")
  town          String  @default("")
  region        String  @default("")
  postcode      String  @default("")
  latitude      Float?
  longitude     Float?
  phone         String?
  email         String?
  openingHours  String? @db.Text
  websiteUrl    String?
  avatarUrl     String?
  coverPhotoUrl String?
  /// Idempotent import key, e.g. ktm:824 or fox:row-2
  sourceKey     String  @unique
  importSource  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brandLinks                   DealerBrand[]
  GiveawayEnrollmentsNearest   GiveawayEnrollment[] @relation("GiveawayEnrollmentNearestDealer")
  GiveawayEnrollmentsPreferred GiveawayEnrollment[] @relation("GiveawayEnrollmentPreferredDealer")

  @@index([latitude, longitude])
  @@index([region, town])
  @@map("Dealers")
}

model DealerBrand {
  id         String   @id @default(cuid())
  dealerId   String
  crmBrandId String
  createdAt  DateTime @default(now())

  dealer   Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  crmBrand CrmBrand @relation(fields: [crmBrandId], references: [id], onDelete: Cascade)

  @@unique([dealerId, crmBrandId])
  @@index([crmBrandId])
  @@map("DealerBrands")
}

model BrandCategory {
  id String @id @default(cuid())

  brandId    String
  categoryId String

  createdAt DateTime @default(now())

  // Relations
  brand    CrmBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([brandId, categoryId])
  @@map("brand_categories")
}

enum PackageLevel {
  STARTER
  ENTRY
  GROWTH
  IMPACT
  LEADERSHIP
  INNOVATOR
  LEGACY
}

enum DealStatus {
  PROSPECT // Initial contact/interest
  PROPOSAL_SENT // Proposal has been sent
  NEGOTIATION // In active negotiation
  CONFIRMED // Deal confirmed but not yet active
  ACTIVE // Currently active deal
  LOST // Deal was lost
  CANCELLED // Deal was cancelled
}

model Deal {
  id String @id @default(cuid())

  brandId String

  // Deal details
  level       PackageLevel?
  status      DealStatus    @default(PROSPECT)
  isConfirmed Boolean       @default(false)

  // Financial
  yearlyValue  Float?
  contractTerm Int? // Contract length in years
  startDate    DateTime?
  endDate      DateTime?

  // Deal management
  probability   Int     @default(50) // Probability percentage (0-100)
  assignedUser  String? // Assigned user (Chris, Brent, Wes, Chase)
  notes         String? // General notes about the deal
  internalNotes String? // Internal team notes

  // Contact information
  primaryContact         String?
  primaryContactJobTitle String?
  contactEmail           String?
  contactPhone           String?

  secondaryContact         String?
  secondaryContactJobTitle String?
  secondaryContactEmail    String?
  secondaryContactPhone    String?

  // Deal source/attribution
  source     String? // Where the lead came from
  referredBy String? // Who referred this deal

  // Important dates
  proposalSentAt DateTime?
  lastContactAt  DateTime?
  nextFollowUpAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  brand CrmBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  // tier   PackageTier? @relation(fields: [tierId], references: [id])
  // tierId String?

  @@map("deals")
}

// Package Tiers for standardized sponsorship offerings
model PackageTier {
  id          String  @id @default(cuid())
  name        String // "Gold", "Silver", "Bronze"
  description String?

  // Financial
  yearlyValue Float?

  // Relations
  brand       CrmBrand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId     String
  obligations ContractObligation[]
  // deals       Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("PackageTiers")
}

// Trackable contract obligations for each tier
model ContractObligation {
  id          String         @id @default(cuid())
  type        ObligationType
  requirement Json // Flexible storage for different obligation types
  weight      Float          @default(1.0) // Importance weight for compliance score

  // Relations
  tier   PackageTier @relation(fields: [tierId], references: [id], onDelete: Cascade)
  tierId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ContractObligations")
}

enum ObligationType {
  BRAND_MENTION // Mention brand X times per period
  HASHTAG_USAGE // Use specific hashtags X times
  TAGGED_POST // Tag brand account in posts
  MIN_RACES // Race at least X times
  MIN_PODIUMS // Get X podium finishes
  MIN_WINS // Win X races
  SPECIFIC_EVENT // Race/finish at specific event
  LORETTAS_QUALIFY // Qualify for Loretta's
  LORETTAS_FINISH // Top X finish at Loretta's
  MAINTAIN_RANKING // Stay in top X in rankings
  MIN_ENGAGEMENT_RATE // Maintain X% engagement
  CONTENT_FREQUENCY // Post at least X times
  SERIES_PARTICIPATION // Race in specific series
}

// =============================================================================
// BRAND PROGRAM MODELS - Automated Rider Support Programs
// =============================================================================

// Maps users to brands they can administrate
model BrandAdmin {
  id         String   @id @default(cuid())
  userId     String
  crmBrandId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  crmBrand CrmBrand @relation(fields: [crmBrandId], references: [id], onDelete: Cascade)

  @@unique([userId, crmBrandId])
  @@index([userId])
  @@index([crmBrandId])
  @@map("BrandAdmins")
}

// Brand sponsorship program configuration
model BrandProgram {
  id               String   @id @default(cuid())
  crmBrandId       String   @unique
  goal             String // 'recruit', 'engagement', 'sales', 'visibility'
  isActive         Boolean  @default(false)
  autoApprove      Boolean  @default(false)
  autoPayment      Boolean  @default(false)
  requiresContract Boolean  @default(true)
  notifyOnApply    Boolean  @default(true)
  notifyOnComplete Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  crmBrand          CrmBrand           @relation(fields: [crmBrandId], references: [id], onDelete: Cascade)
  brandProgramTiers BrandProgramTier[]

  @@index([crmBrandId])
  @@index([isActive])
  @@map("BrandPrograms")
}

// Tiers within a brand's sponsorship program
model BrandProgramTier {
  id                             String  @id @default(cuid())
  brandProgramId                 String
  name                           String
  description                    String?
  termsAndConditions             String? // Custom terms and conditions for this tier
  value                          Float // Benefit value (e.g., 10 for 10% discount)
  sortOrder                      Int     @default(0)
  isActive                       Boolean @default(true)
  isPubliclyVisible              Boolean @default(true) // Whether this tier is visible on the public brand page
  isLocked                       Boolean @default(false) // Whether this tier is locked (visible but not actionable)
  isApplicationRequired          Boolean @default(false) // When true, riders submit an application; brand approves before activation
  isExternallyManaged            Boolean @default(false) // Discount fulfilled outside Prospect; rider confirms email on accept; brand notified
  externalManagementEmailAddress String? // Inbox where Prospect sends rider handoff when isExternallyManaged (required when flag is true)

  // Qualification requirements
  minCareerScore   Int?
  minSocialScore   Int?
  minFollowerCount Int? // Minimum total followers (Instagram + TikTok + YouTube)
  minPodiums       Int?
  maxRiders        Int? // Cap on number of riders allowed in this tier (null = no cap)

  // Optional filters
  regions String? // JSON array of US states
  classes String? // JSON array of bike classes

  // Discount code configuration
  codeType  String? // 'fixed' or 'custom'
  fixedCode String? // The discount code if codeType is 'fixed'
  color     String? // Display color for tier

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  brandProgram         BrandProgram                 @relation(fields: [brandProgramId], references: [id], onDelete: Cascade)
  brandTierObligations BrandTierObligation[]
  brandOffers          BrandOffer[]
  customCodes          BrandProgramTierCustomCode[]

  @@index([brandProgramId])
  @@index([isActive])
  @@map("BrandProgramTiers")
}

// Pool of one-time discount codes for tiers with codeType = custom (assigned when a rider's offer becomes active)
model BrandProgramTierCustomCode {
  id                 String   @id @default(cuid())
  brandProgramTierId String
  code               String
  brandOfferId       String?  @unique
  createdAt          DateTime @default(now())

  brandProgramTier BrandProgramTier @relation(fields: [brandProgramTierId], references: [id], onDelete: Cascade)
  brandOffer       BrandOffer?      @relation(fields: [brandOfferId], references: [id], onDelete: SetNull)

  @@unique([brandProgramTierId, code])
  @@index([brandProgramTierId])
  @@map("BrandProgramTierCustomCodes")
}

// Obligations/requirements for a specific tier
model BrandTierObligation {
  id                 String   @id @default(cuid())
  brandProgramTierId String
  type               String
  description        String
  targetValue        Int?
  frequency          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  brandProgramTier BrandProgramTier @relation(fields: [brandProgramTierId], references: [id], onDelete: Cascade)

  @@index([brandProgramTierId])
  @@map("BrandTierObligations")
}

// Offers made to riders (applications, acceptances, rejections)
model BrandOffer {
  id                   String    @id @default(cuid())
  crmBrandId           String
  brandProgramTierId   String
  riderId              String
  status               String // 'applied', 'accepted', 'rejected', 'active', 'cancelled'
  isManualOffer        Boolean   @default(false)
  appliedAt            DateTime  @default(now())
  respondedAt          DateTime?
  completedAt          DateTime?
  notes                String?
  externalHandoffEmail String? // Rider-confirmed email for externally managed tiers (set on accept)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Compliance tracking fields
  lastComplianceCheckCompleted DateTime?
  isCompliant                  Boolean   @default(true)
  numberOfComplianceViolations Int       @default(0)
  numberOfObligations          Int       @default(0)

  // Relations
  brandProgramTier       BrandProgramTier            @relation(fields: [brandProgramTierId], references: [id], onDelete: Restrict)
  crmBrand               CrmBrand                    @relation(fields: [crmBrandId], references: [id], onDelete: Cascade)
  rider                  RiderId                     @relation(fields: [riderId], references: [id], onDelete: Cascade)
  complianceItems        BrandOfferComplianceItem[]
  assignedTierCustomCode BrandProgramTierCustomCode?

  @@index([crmBrandId])
  @@index([riderId])
  @@index([status])
  @@index([isCompliant])
  @@map("BrandOffers")
}

// Compliance violations for brand offers
model BrandOfferComplianceItem {
  id                    String   @id @default(cuid())
  brandOfferId          String
  brandTierObligationId String
  obligationType        String
  description           String
  requiredValue         Float? // What the obligation requires (e.g., 10 races)
  actualValue           Float? // What the rider actually achieved (e.g., 7 races)
  checkDate             DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  brandOffer BrandOffer @relation(fields: [brandOfferId], references: [id], onDelete: Cascade)

  @@index([brandOfferId])
  @@index([checkDate])
  @@map("BrandOfferComplianceItems")
}

// Brand ↔ rider messaging threads (one per brand + rider)
model BrandRiderMessageThread {
  id                       String    @id @default(cuid())
  crmBrandId               String
  riderId                  String
  lastMessageAt            DateTime?
  lastMessagePreview       String?   @db.Text
  lastSenderType           String? // 'brand' | 'rider'
  riderLastReadAt          DateTime?
  brandLastReadAt          DateTime?
  /// When set, thread is omitted from brand communications inbox for all brand admins.
  hiddenFromBrandInboxAt   DateTime?
  /// When set, thread is omitted from rider inbox for all users who manage this rider.
  hiddenFromRiderInboxAt   DateTime?
  /// Rider tapped "mark unread" (or legacy client); cleared on rider mark-read or new brand message / rider reply.
  riderInboxUnreadPinnedAt DateTime?
  /// Brand admin tapped "mark unread"; cleared on brand mark-read or new rider message / brand reply.
  brandInboxUnreadPinnedAt DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  crmBrand CrmBrand            @relation(fields: [crmBrandId], references: [id], onDelete: Cascade)
  rider    RiderId             @relation(fields: [riderId], references: [id], onDelete: Cascade)
  messages BrandRiderMessage[]

  @@unique([crmBrandId, riderId])
  @@index([crmBrandId])
  @@index([riderId])
  @@index([lastMessageAt])
  @@map("BrandRiderMessageThreads")
}

model BrandRiderMessage {
  id              String   @id @default(cuid())
  threadId        String
  riderId         String // Rider profile this brand–rider message belongs to (same as thread.riderId)
  body            String   @db.Text
  senderType      String // 'brand' | 'rider'
  // Optional audit: app user who sent (brand admin or claimant). No User FK.
  sentByUserId    String?
  parentMessageId String?
  createdAt       DateTime @default(now())

  thread  BrandRiderMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  rider   RiderId                 @relation(fields: [riderId], references: [id], onDelete: Cascade)
  parent  BrandRiderMessage?      @relation("BrandRiderMessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies BrandRiderMessage[]     @relation("BrandRiderMessageReplies")

  @@index([threadId])
  @@index([riderId])
  @@index([createdAt])
  @@map("BrandRiderMessages")
}

// Rider supported brands (rider showing support for a brand)
model RiderSupportedBrand {
  id        String   @id @default(cuid())
  riderId   String
  brandId   String // CrmBrand ID
  createdAt DateTime @default(now())

  rider RiderId  @relation(fields: [riderId], references: [id], onDelete: Cascade)
  brand CrmBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([riderId, brandId])
  @@index([riderId])
  @@index([brandId])
  @@map("RiderSupportedBrands")
}

// ============================================================================
// PROFESSIONAL RACING MODELS
// ============================================================================

// Professional race event (Supercross, Pro Motocross, SuperMotocross)
model ProRaceEvent {
  id                   String         @id @default(cuid())
  name                 String // "Pittsburgh", "High Point"
  seriesName           String // "2025 Monster Energy AMA Supercross"
  seriesType           String // "supercross", "pro-motocross", "supermotocross"
  season               Int // 2025
  roundNumber          Int? // 15, or null
  date                 DateTime
  location             String
  city                 String?
  state                String?
  eventUrl             String
  scoringSystemEventId String // External event ID from source
  scoringSystemType    String // "supercross-live", "promotocross", "supermotocross"
  formatType           String         @default("single-main") // "single-main", "dual-moto"
  trackMapImageUrl     String? // Track map image URL
  isHidden             Boolean        @default(false)
  createdAt            DateTime       @default(now())
  ProRaceClasses       ProRaceClass[]

  @@unique([scoringSystemType, scoringSystemEventId])
  @@index([seriesType, season])
  @@index([date])
  @@map("ProRaceEvents")
}

// Professional race class within an event
model ProRaceClass {
  id                        String          @id @default(cuid())
  proRaceEventId            String
  className                 String // "250", "250 East", "250 West", "450", "SMX Next", "KTM Junior Challenge"
  date                      DateTime
  scoringSystemEventClassId String // External class/race ID
  ProRaceEvent              ProRaceEvent    @relation(fields: [proRaceEventId], references: [id], onDelete: Cascade)
  ProRaceResults            ProRaceResult[]

  @@unique([proRaceEventId, scoringSystemEventClassId])
  @@index([proRaceEventId])
  @@index([className])
  @@map("ProRaceClasses")
}

// Professional race result
model ProRaceResult {
  id                    String       @id @default(cuid())
  proRaceClassId        String
  riderId               String
  name                  String // Lowercase for consistency
  hometown              String?
  bikeNumber            String
  manufacturer          String
  overallPosition       String // "1st", "2nd", "3rd"
  overallPositionNumber Int // 1, 2, 3
  // Moto-specific fields (for Pro Motocross dual-moto format)
  motoOnePosition       String?
  motoOnePositionNumber Int?
  motoTwoPosition       String?
  motoTwoPositionNumber Int?
  // Additional metadata
  holeshot              Boolean      @default(false)
  promoterRiderId       String? // External rider ID
  createdAt             DateTime     @default(now())
  ProRaceClass          ProRaceClass @relation(fields: [proRaceClassId], references: [id], onDelete: Cascade)
  RiderId               RiderId      @relation(fields: [riderId], references: [id])

  @@unique([proRaceClassId, riderId])
  @@index([riderId])
  @@index([proRaceClassId])
  @@index([overallPositionNumber])
  @@map("ProRaceResults")
}

// Professional championship standings (stored per season)
model ProChampionshipStanding {
  id                  String   @id @default(cuid())
  riderId             String
  championshipType    String // "supercross", "pro-motocross", "supermotocross"
  season              Int // 2025, 2024, etc.
  className           String // "250", "250 East", "250 West", "450"
  position            Int // Current position in championship
  totalPoints         Int // Total championship points
  pointsBehind        Int // Points behind leader
  // SMX-specific fields
  regularSeasonPoints Int? // SX + MX points combined (for SMX)
  playoffPoints       Int? // SMX playoff points
  // Metadata
  asOfRound           String? // "Round 15" or "Playoff 2"
  asOfDate            DateTime @default(now())
  isFinal             Boolean  @default(false) // True when season ends
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  RiderId             RiderId  @relation(fields: [riderId], references: [id])

  @@unique([riderId, championshipType, season, className])
  @@index([championshipType, season, className, position])
  @@index([riderId, season])
  @@map("ProChampionshipStandings")
}

// ============================================================================
// DIRTY 100 (MOTOPLAYGROUND) MODELS
// ============================================================================

model DirtyOneHundredClass {
  id         String                       @id @default(cuid())
  year       Int // e.g. 2026
  classSlug  String // URL slug e.g. "250-b", "smx-next"
  classTitle String // Display title e.g. "250 B", "SMX NEXT"
  Results    DirtyOneHundredClassResult[]

  @@unique([year, classSlug])
  @@index([year])
  @@map("DirtyOneHundredClasses")
}

model DirtyOneHundredClassResult {
  id                     String               @id @default(cuid())
  dirtyOneHundredClassId String
  promoterRiderId        String // Unique rider URL e.g. https://www.dirty100.com/leaderboards/brennan/hunter
  position               Int // Overall position (1, 2, 3...)
  firstName              String
  lastName               String
  bikeNumber             String
  manufacturer           String // YAM, KAW, KTM, HSQ, etc.
  points                 Int
  pointsBehind           Int // Can be negative (e.g. -150)
  riderId                String?
  DirtyOneHundredClass   DirtyOneHundredClass @relation(fields: [dirtyOneHundredClassId], references: [id], onDelete: Cascade)
  RiderId                RiderId?             @relation(fields: [riderId], references: [id])

  @@unique([dirtyOneHundredClassId, promoterRiderId])
  @@index([dirtyOneHundredClassId])
  @@index([riderId])
  @@index([dirtyOneHundredClassId, position])
  @@map("DirtyOneHundredClassResults")
}

// ============================================================================
// TRAINING FACILITIES MODELS
// ============================================================================

model TrainingFacility {
  id                      String                  @id @default(cuid())
  title                   String
  trainers                String? // Comma-separated list of trainer names
  url                     String?
  city                    String                  @default("")
  state                   String                  @default("")
  profilePicUrl           String? // Avatar image
  coverPhotoUrl           String? // Cover image
  description             String?
  latitude                Float?
  longitude               Float?
  isGeoCoded              Boolean                 @default(false)
  isFeatured              Boolean                 @default(false)
  isClaimed               Boolean                 @default(false)
  isHidden                Boolean                 @default(false)
  featuredSpot            Int? // Sort order for featured facilities
  // Social media links
  instagram               String                  @default("")
  instagramProfileId      String?
  facebook                String                  @default("")
  youtube                 String                  @default("")
  youtubeProfileId        String?
  tiktok                  String                  @default("")
  tiktokProfileId         String?
  twitter                 String                  @default("")
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  // Relations
  TrainingFacilityAdmins  TrainingFacilityAdmin[]
  RiderTrainingFacilities RiderTrainingFacility[]
  InstagramProfile        InstagramProfile?       @relation(fields: [instagramProfileId], references: [id])
  TikTokProfile           TikTokProfile?          @relation(fields: [tiktokProfileId], references: [id])
  YouTubeProfile          YouTubeProfile?         @relation(fields: [youtubeProfileId], references: [id])

  @@index([city, state])
  @@index([isFeatured])
  @@index([isClaimed])
  @@index([latitude, longitude])
  @@map("TrainingFacilities")
}

// Maps users to training facilities they can administrate
model TrainingFacilityAdmin {
  id                 String   @id @default(cuid())
  userId             String
  trainingFacilityId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingFacility TrainingFacility @relation(fields: [trainingFacilityId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingFacilityId])
  @@index([userId])
  @@index([trainingFacilityId])
  @@map("TrainingFacilityAdmins")
}

// Links riders to training facilities
model RiderTrainingFacility {
  id                 String   @id @default(cuid())
  riderId            String
  trainingFacilityId String
  createdAt          DateTime @default(now())

  // Relations
  rider            RiderId          @relation(fields: [riderId], references: [id], onDelete: Cascade)
  trainingFacility TrainingFacility @relation(fields: [trainingFacilityId], references: [id], onDelete: Cascade)

  @@unique([riderId, trainingFacilityId])
  @@index([riderId])
  @@index([trainingFacilityId])
  @@map("RiderTrainingFacilities")
}

// ============================================================================
// BRAND ADVERTISING MODELS
// ============================================================================

// Marketing wallet for brand advertising credits
model BrandAdWallet {
  id        String   @id @default(cuid())
  brandId   String   @unique
  balance   Float    @default(0) // Current credit balance
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  brand        CrmBrand                   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  transactions BrandAdWalletTransaction[]

  @@map("BrandAdWallets")
}

// Transaction history for wallet credits
model BrandAdWalletTransaction {
  id                    String   @id @default(cuid())
  walletId              String
  amount                Float // Positive for credits, negative for debits
  type                  String // "CREDIT", "DEBIT", "MANUAL_ADJUST", "AD_PURCHASE", "REFUND", "STRIPE_REFILL"
  description           String?
  createdBy             String? // User ID who created the transaction (for manual adjustments)
  stripePaymentIntentId String? // Stripe payment intent ID for refills
  createdAt             DateTime @default(now())

  // Relations
  wallet BrandAdWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
  @@index([type])
  @@index([stripePaymentIntentId])
